# Optional tuning
OMP_NUM_THREADS=6
GGML_NUM_THREADS=6
RESTART_DAEMON_LOG_LEVEL=DEBUG

# --- Local llama.cpp (default) ---
# Use with: python -m restart --config restart/config.local.json
LLM_BASE_URL=http://127.0.0.1:8080
LLM_MODEL=openai/Gemma-4-E4B-Uncensored-HauhauCS-Aggressive-Q5_K_M
LLM_API_KEY=dummy

# --- Google Gemini ---
# To use Gemini: comment out the local block above, uncomment below,
# and run with: python -m restart --config restart/config.gemini.json
#LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
#LLM_MODEL=gemini-3.1-flash-lite-preview
#LLM_API_KEY=AIzaSyCRnks2sgeGPdzWuh--p0wQ98SZlgG0m7Y
