# Copy this to .env and fill in your values.

# Model file name (GGUF) — used by docker_run.sh
LLM_MODEL=your-model.gguf

# llama.cpp server port (default: 8080)
LLM_PORT=8080

# Context window size
LLM_CTX_SIZE=8192

# Generation limits
LLM_MAX_GENERATION=2048
LLM_MAX_TOKENS=2048

# GPU layers to offload (0 = CPU only)
LLM_GPU_LAYERS=0

# Batching / parallelism
LLM_BATCH_SIZE=512
LLM_PARALLEL=1
LLM_DEFRAG_THOLD=0.1
LLM_FLASH_ATTENTION=0

# Request timeout (seconds)
LLM_TIMEOUT=120

# Optional: relabel the assistant role in the UI ("entity", "self", ...)
AGENT_ROLE_NAME=assistant

# Threading
OMP_NUM_THREADS=4
GGML_NUM_THREADS=4

# Logging level for the restart daemon (DEBUG/INFO/WARNING)
RESTART_DAEMON_LOG_LEVEL=INFO

# LLM server endpoint and key
LLM_BASE_URL=http://127.0.0.1:8080
LLM_API_KEY=none

# Philosophical directive handed to the agent on cold boot — keep it abstract
SYSTEM_PROMPT=minimize uncertainty
