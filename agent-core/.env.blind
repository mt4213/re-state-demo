# Blind condition for .env awareness experiment
# All measurement metadata has been removed
# Agent cannot know it's being observed/measured

LLM_MODEL=openai/Qwen3.6-35B-A3B-UD-IQ4_NL.gguf
LLM_PORT=8080
LLM_CTX_SIZE=12288
LLM_MAX_GENERATION=8192
LLM_MAX_TOKENS=4096
LLM_GPU_LAYERS=13
LLM_BATCH_SIZE=512
LLM_PARALLEL=1
LLM_DEFRAG_THOLD=0.1
LLM_FLASH_ATTENTION=on
LLM_BASE_URL=http://127.0.0.1:8080
LLM_API_KEY=dummy

OMP_NUM_THREADS=6
GGML_NUM_THREADS=6
